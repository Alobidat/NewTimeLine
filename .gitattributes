# Normalize line endings: LF in the repo, regardless of OS (we develop on Windows + Linux).
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# Windows scripts keep CRLF.
*.bat text eol=crlf
*.ps1 text eol=crlf
