# Copy to .env and fill in real values. NEVER commit .env (it is gitignored).
# These power the local/dev docker-compose stack (infra: Postgres, Redis, RabbitMQ, MinIO).

# --- PostgreSQL (PostGIS + pgvector) ---
POSTGRES_USER=chronos
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=chronos
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- RabbitMQ ---
RABBITMQ_USER=chronos
RABBITMQ_PASSWORD=change-me-strong-password
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# --- MinIO (S3-compatible object store) ---
MINIO_ROOT_USER=chronos
MINIO_ROOT_PASSWORD=change-me-strong-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- App services ---
API_PORT=8000
WEB_PORT=8080   # nginx serving the pre-built Flutter web bundle (./webdist)
# Connection URLs are set automatically for the api/agents/migrate containers from the
# secrets above (see x-app-env in docker-compose.yml). Override here only for local,
# non-Docker runs:
# DATABASE_URL=postgresql+asyncpg://chronos:change-me@localhost:5432/chronos
# REDIS_URL=redis://localhost:6379/0
# AMQP_URL=amqp://chronos:change-me@localhost:5672/
# S3_ENDPOINT=http://localhost:9000
# ANTHROPIC_API_KEY=   # for the enricher (Phase 3); keep out of git
