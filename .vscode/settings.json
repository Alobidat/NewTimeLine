{
  "// note": "Workspace settings for the LXC dev box (Remote-SSH).",
  "dart.flutterSdkPath": "/opt/flutter",
  "dart.lineLength": 100,
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvInCurrentTerminal": true,
  "files.exclude": {
    "**/.dart_tool": true,
    "**/build": true,
    "**/.venv": true,
    "**/*.egg-info": true
  },
  "search.exclude": {
    "**/.venv": true,
    "**/build": true,
    "**/.dart_tool": true
  }
}
