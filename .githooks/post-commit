#!/bin/sh
# Auto-deploy every commit. Picks the deploy by platform and runs it detached (does not block
# the commit); progress is written to deploy.log at the repo root.
#
# Active only when git is told to use this hooks dir:  git config core.hooksPath .githooks
ROOT="$(git rev-parse --show-toplevel)"
case "$(uname -s)" in
  Linux | Darwin)
    # On the LXC dev box: build + ship locally.
    nohup bash "$ROOT/scripts/deploy-lxc.sh" >/dev/null 2>&1 &
    ;;
  *)
    # Windows (Git Bash / MINGW): build on the dev machine, scp to the LXC.
    PS1WIN="$(cygpath -w "$ROOT/scripts/deploy-lxc.ps1" 2>/dev/null || echo "$ROOT/scripts/deploy-lxc.ps1")"
    powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \
      "Start-Process powershell -WindowStyle Hidden -ArgumentList @('-NoProfile','-ExecutionPolicy','Bypass','-File','$PS1WIN')" \
      >/dev/null 2>&1
    ;;
esac
exit 0
