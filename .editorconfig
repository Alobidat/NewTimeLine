# Consistent indentation across editors. See docs/engineering-standards.md §1.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false  # markdown line breaks

[Makefile]
indent_style = tab
